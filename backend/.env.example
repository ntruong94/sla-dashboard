# ─── SLA Dashboard Backend — Environment Variables ────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.
# On Railway / Render: add these via the platform's Environment Variables panel.
# ──────────────────────────────────────────────────────────────────────────────

# ── SQL Server connection ─────────────────────────────────────────────────────
# Server name or IP. Use 'localhost' when DB is on the same machine.
DB_SERVER=localhost

# SQL Server instance port (default 1433; omit if using a named instance backslash)
DB_PORT=1433

# SQL Server database name
DB_DATABASE=MySEReport

# SQL login credentials (leave blank to use Windows Authentication instead)
DB_USER=
DB_PASSWORD=

# ── JWT authentication ────────────────────────────────────────────────────────
# Must be at least 32 characters, randomly generated.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# If blank, the hardcoded default list in server.js is used (includes localhost).
# Example: https://sla.mezy.com.au,https://sla-dashboard.vercel.app
ALLOWED_ORIGINS=

# ── Runtime mode ─────────────────────────────────────────────────────────────
# Set to 'production' on the live server.
# Controls error verbosity: production returns generic messages only.
NODE_ENV=development

# ── Optional: mock data mode ──────────────────────────────────────────────────
# Set to 'true' to use in-memory mock data instead of SQL Server (useful for CI)
USE_MOCK=false

# ── Optional: server port ────────────────────────────────────────────────────
# Defaults to 5000 if not set.
PORT=5000
