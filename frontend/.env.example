# ─── SLA Dashboard Frontend — Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is listed in .gitignore.
#
# On Vercel: add these via Project → Settings → Environment Variables.
# On Cloudflare Pages: add via Pages project → Settings → Environment variables.
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────────────────────
# The public URL where the backend (server.js) is reachable.
# Leave blank when running frontend locally with Vite's dev proxy (localhost).
#
# For production pointing to the Cloudflare Named Tunnel:
#   VITE_API_BASE=https://your-tunnel-name.cfargotunnel.com
#
# For the ngrok static domain (free plan):
#   VITE_API_BASE=https://balmy-accurate-handpick.ngrok-free.app
VITE_API_BASE=
