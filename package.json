{
  "name": "sla-dashboard",
  "scripts": {
    "start": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && node server.js",
    "start:frontend": "cd frontend && npm run dev -- --host"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
